<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="All_Messenger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:All_Messenger"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:All_Messenger.Pages"
    mc:Ignorable="d"
    Title="All-in-One Messenger">

    <Grid>
        <!-- Title Bar -->
        <Grid x:Name="TitleBar" Height="36" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT TITLE -->
            <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center"
                Spacing="8"
                Margin="12,0">

                <Image Source="ms-appx:///Assets/logo.png"
                    Width="20"
                    Height="20"/>

                <TextBlock Text="All-in-One Messenger"
                    VerticalAlignment="Center"/>

            </StackPanel>

            <!-- RIGHT BUTTONS -->
            <StackPanel Orientation="Horizontal"
                    Grid.Column="1"
                    Spacing="1"
                    Margin="0,0,142,0">

                <Button Click="Reload_Click"
                        Style="{StaticResource TitleBarButtonStyle}">

                    <FontIcon FontFamily="Segoe MDL2 Assets"
                        Glyph="&#xE72C;"
                        FontSize="16"/>

                </Button>

                <ToggleButton x:Name="DarkModeToggle"
                    Style="{StaticResource TitleBarToggleButtonStyle}"
                    Checked="DarkMode_Checked"
                    Unchecked="DarkMode_Unchecked">

                    <FontIcon x:Name="ThemeIcon"
                        Glyph="&#xE706;"
                        FontSize="16"
                        FontFamily="Segoe MDL2 Assets"/>

                </ToggleButton>
            </StackPanel>
        </Grid>

        <NavigationView x:Name="NavView"
                        Margin="0,40,0,0"
                        PaneDisplayMode="Left"
                        IsPaneOpen="False"
                        OpenPaneLength="192"
                        CompactPaneLength="48"
                        IsBackButtonVisible="Collapsed"
                        SelectionChanged="NavView_SelectionChanged">

            <NavigationView.Resources>
                <Style TargetType="NavigationViewItem">
                    <Setter Property="MinHeight" Value="44"/>
                    <Setter Property="FontSize" Value="20"/>
                </Style>
            </NavigationView.Resources>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Messenger" Tag="MessengerPage">
                    <NavigationViewItem.Icon>
                        <ImageIcon x:Name="MessengerIcon"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Zalo" Tag="ZaloPage">
                    <NavigationViewItem.Icon>
                        <ImageIcon x:Name="ZaloIcon"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Teams" Tag="TeamsPage">
                    <NavigationViewItem.Icon>
                        <ImageIcon x:Name="TeamsIcon"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid>
                <pages:MessengerPage x:Name="MessengerPage" Visibility="Collapsed"/>
                <pages:ZaloPage      x:Name="ZaloPage"      Visibility="Collapsed"/>
                <pages:TeamsPage     x:Name="TeamsPage"     Visibility="Collapsed"/>
                <pages:SettingPage   x:Name="SettingPage"  Visibility="Collapsed"/>

                <!-- Welcome view — chỉ hiện lần đầu, ẩn sau khi chọn tab -->
                <Grid x:Name="WelcomeView">
                    <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">

                        <Image Source="ms-appx:///Assets/logo.png"
                   Width="80" Height="80"
                   HorizontalAlignment="Center"/>

                        <TextBlock Text="All-in-One Messenger"
                       FontSize="28"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>

                        <TextBlock Text="Chọn một ứng dụng để bắt đầu"
                       FontSize="14"
                       Opacity="0.6"
                       HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
